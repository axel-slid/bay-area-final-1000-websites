{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": true,
  "routes": [
    {
      "src": "/data.json",
      "dest": "/data.json"
    },
    {
      "src": "/robots.txt",
      "dest": "/robots.txt"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}
